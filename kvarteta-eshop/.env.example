# Supabase Integration
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Zásilkovna / Packeta widget (client-side, vyžadované v PROD)
VITE_ZASILKOVNA_API_KEY=

# GP Webpay / ČSOB (volitelné, fallback je test merchant)
VITE_GP_WEBPAY_MERCHANT_ID=M1HTTEST
VITE_GP_WEBPAY_GATEWAY_URL=https://test.gpwebpay.com/pgw/pay.do

# Bankovní spojení pro QR platby (Fio Banka, kód 2010) — REQUIRED v PROD
# Pokud chybí v produkci, frontend padne při importu payment.ts (paymentEnv throw).
# Skutečné hodnoty si doplň ze svého Fio internetbankingu.
VITE_BANK_ACCOUNT=2202066277/2010
VITE_BANK_CODE=2010
VITE_BANK_IBAN=CZ4720100000002202066277

# N8N automatizace (fakturace, dobropisy)
VITE_N8N_WEBHOOK_URL=https://n8n.example.com/webhook/new-order
VITE_N8N_CREDIT_NOTE_WEBHOOK_URL=https://n8n.example.com/webhook/dobropis
# Sdílený secret pro veřejný N8N webhook (CheckoutPage) — n8n workflow validuje X-Webhook-Secret.
# Pokud prázdný, header se neposílá (zpětně kompatibilní). NASTAV V PROD.
VITE_N8N_WEBHOOK_SECRET=
