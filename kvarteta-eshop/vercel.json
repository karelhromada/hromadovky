{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "regions": ["fra1"],
  "rewrites": [
    {
      "source": "/((?!api/|favicon\\.ico|robots\\.txt|.*\\.(?:js|css|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|eot|map)).*)",
      "destination": "/index.html"
    }
  ]
}
